PORT=3001
NODE_ENV=development

# PostgreSQL connection string (required)
DATABASE_URL=postgres://user:password@localhost:5432/rydercup

# PostgreSQL test database (required for running tests)
DATABASE_URL_TEST=postgres://user:password@localhost:5432/rydercup_test

# JWT signing secret (defaults to 'supersecret' in dev)
JWT_SECRET=your-secret-here
