        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",

        "@types/node": "^20.0.0",
        "@types/pg": "^8.16.0",
        "@types/uuid": "^10.0.0",
        "supertest": "^6.3.3",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.0.0",
        "vitest": "^0.34.0",
        "xlsx": "^0.18.5"
