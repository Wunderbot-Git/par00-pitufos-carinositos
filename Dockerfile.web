FROM node:20-alpine AS builder

WORKDIR /app
COPY package*.json ./
COPY packages/web/package.json packages/web/
COPY packages/shared/package.json packages/shared/

RUN npm ci

COPY packages/web packages/web/
COPY packages/shared packages/shared/

RUN npm run build -w @ryder-cup/shared

# Allow injecting API URL during build time
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

RUN npm run build -w @ryder-cup/web

FROM node:20-alpine AS runner

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000

# Next.js standalone mode bundles dependencies locally
# This avoids needing the root node_modules for the web app
COPY --from=builder /app/packages/web/.next/standalone ./
COPY --from=builder /app/packages/web/.next/static ./packages/web/.next/static
COPY --from=builder /app/packages/web/public ./packages/web/public

EXPOSE 3000
CMD ["node", "packages/web/server.js"]
